{
    "name": "Debug C++ File",
    "type": "cppdbg",
    "request": "launch",
    // Points to the .exe created by the compiler
    "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
    "args": [],
    "stopAtEntry": false,
    "cwd": "${fileDirname}", 
    "environment": [],
    "externalConsole": false, // Change to true if you want a separate window
    "MIMode": "gdb",
    "miDebuggerPath": "C:\\MinGW\\bin\\gdb.exe",
    "setupCommands": [
        {
            "description": "Enable pretty-printing for gdb",
            "text": "-enable-pretty-printing",
            "ignoreFailures": true
        }
    ],
    "preLaunchTask": "C/C++: g++.exe build active file" 
}